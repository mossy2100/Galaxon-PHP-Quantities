#!/usr/bin/env bash
#
# Run phpunit with coverage for a given testsuite.
#
# Usage:
#   scripts/test              # all tests (no suite filter)
#   scripts/test all          # all tests (no suite filter)
#   scripts/test unit         # fast offline tests
#   scripts/test currencies   # live exchange-rate API tests (slow, consumes quota)
#
set -euo pipefail

suite="${1:-all}"

cd "$(dirname "$0")/.."

args=(
    -d xdebug.mode=coverage
    vendor/bin/phpunit
    --coverage-html build/coverage
    --coverage-clover build/logs/clover.xml
    --do-not-cache-result
)

if [[ "$suite" != "all" ]]; then
    args+=(--testsuite="$suite")
fi

exec php "${args[@]}"
