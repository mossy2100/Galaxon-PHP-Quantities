<?xml version="1.0" encoding="UTF-8"?>
<phpunit bootstrap="vendor/autoload.php"
         colors="true"
         cacheResult="false"
         beStrictAboutOutputDuringTests="true"
         beStrictAboutChangesToGlobalState="true"
         displayDetailsOnTestsThatTriggerDeprecations="true"
         displayDetailsOnTestsThatTriggerErrors="true"
         displayDetailsOnTestsThatTriggerNotices="true"
         displayDetailsOnTestsThatTriggerWarnings="true"
         displayDetailsOnPhpunitDeprecations="true">

    <testsuites>
        <testsuite name="unit">
            <directory>tests/NonCurrencies</directory>
        </testsuite>
        <testsuite name="currencies">
            <directory>tests/Currencies</directory>
        </testsuite>
    </testsuites>

    <!-- The default "unit" suite (set via defaultTestSuite above) runs the fast,
         offline tests. The "currencies" suite hits live exchange rate APIs and
         consumes quota; run it opt-in via "composer test:currencies". -->

    <coverage includeUncoveredFiles="true">
        <report>
            <html outputDirectory="build/coverage"/>
        </report>
    </coverage>

    <source>
        <include>
            <directory>src</directory>
        </include>
        <exclude>
            <directory>src/Currencies/data</directory>
        </exclude>
    </source>
</phpunit>
